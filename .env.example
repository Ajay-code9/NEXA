# Example environment variables
# Add only the values your deployment requires.
VITE_APP_URL="http://localhost:3000"

# --- Contact form → email (Vercel serverless `/api/contact`) ---
# 1) Create a free Resend account: https://resend.com
# 2) Create an API key and add it in Vercel → Project → Settings → Environment Variables
# 3) Set CONTACT_TO_EMAIL to the inbox where you want leads (your work email is fine)
# 4) Optional: CONTACT_FROM_EMAIL — after you verify your domain in Resend, use e.g.
#    "NEXA <leads@yourdomain.com>". Until then, omit it to use Resend's test sender.
#
# Deploy on Vercel, then connect your GoDaddy domain in Vercel → Domains (DNS changes are done at GoDaddy per Vercel's instructions).
#
# Local dev: plain `npm run dev` does not run Vercel functions. Use `npx vercel dev` to test submissions locally.
RESEND_API_KEY="re_xxxxxxxx"
# Inbox where leads are delivered (override anytime in Vercel env)
# Inbox where lead notification emails are delivered.
CONTACT_TO_EMAIL="nexabrokerageofficial@gmail.com"
# CONTACT_FROM_EMAIL="NEXA <leads@yourdomain.com>"

# Resend testing note: while using the default sender "NEXA <onboarding@resend.dev>",
# Resend often only allows sending TO the same email address as your Resend account
# until you verify a custom domain. If emails fail, either set CONTACT_TO_EMAIL to
# that account email, or verify your domain in Resend and set CONTACT_FROM_EMAIL.
